# Normalize line endings to LF in the repo and on checkout, so Biome/format
# checks are consistent across macOS, Linux, and Windows (avoids the autocrlf
# "LF will be replaced by CRLF" churn and spurious format lint errors).
* text=auto eol=lf

# Explicit text types
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.json  text eol=lf
*.rs    text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.sh    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binary assets — never normalize
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.icns  binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.wasm  binary
*.dmg   binary
*.msi   binary
